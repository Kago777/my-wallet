generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WalletType {
  cash
  bank
  credit
  investment
}

enum TransactionType {
  income
  expense
}

enum CategoryType {
  income
  expense
}

enum CycleType {
  monthly
  weekly
  yearly
}

enum ReminderType {
  bill_input
  subscription_review
  reconciliation
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  name            String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  wallets         Wallet[]
  categories      Category[]
  reminders       Reminder[]
}

model Wallet {
  id               String            @id @default(uuid())
  name             String
  type             WalletType
  sortOrder        Int               @default(0) @map("sort_order")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  userId           String            @map("user_id")
  user             User              @relation(fields: [userId], references: [id])
  transactions     Transaction[]
  subscriptions    Subscription[]
  recurringIncomes RecurringIncome[]
  recurringBills   RecurringBill[]
  budgets          Budget[]
}

model Transaction {
  id               String           @id @default(uuid())
  amount           Int
  type             TransactionType
  description      String?
  date             DateTime         @default(now())
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  walletId         String           @map("wallet_id")
  wallet           Wallet           @relation(fields: [walletId], references: [id])
  categoryId       String           @map("category_id")
  category         Category         @relation(fields: [categoryId], references: [id])
  subscriptionId   String?          @map("subscription_id")
  subscription     Subscription?    @relation(fields: [subscriptionId], references: [id])
  recurringBillId  String?          @map("recurring_bill_id")
  recurringBill    RecurringBill?   @relation(fields: [recurringBillId], references: [id])
}

model Category {
  id               String            @id @default(uuid())
  name             String
  type             CategoryType
  isDefault        Boolean           @default(false) @map("is_default")
  createdAt        DateTime          @default(now()) @map("created_at")
  userId           String?           @map("user_id")
  user             User?             @relation(fields: [userId], references: [id])
  transactions     Transaction[]
  subscriptions    Subscription[]
  recurringIncomes RecurringIncome[]
  recurringBills   RecurringBill[]
  budgets          Budget[]
}

model Subscription {
  id           String        @id @default(uuid())
  name         String
  amount       Int
  billingDate  Int           @map("billing_date")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  walletId     String        @map("wallet_id")
  wallet       Wallet        @relation(fields: [walletId], references: [id])
  categoryId   String        @map("category_id")
  category     Category      @relation(fields: [categoryId], references: [id])
  transactions Transaction[]
}

model RecurringBill {
  id              String        @id @default(uuid())
  name            String
  estimatedAmount Int           @map("estimated_amount")
  billingDay      Int?          @map("billing_day")
  cycleType       CycleType     @map("cycle_type")
  provider        String?
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  walletId        String        @map("wallet_id")
  wallet          Wallet        @relation(fields: [walletId], references: [id])
  categoryId      String        @map("category_id")
  category        Category      @relation(fields: [categoryId], references: [id])
  transactions    Transaction[]
  reminders       Reminder[]
}

model RecurringIncome {
  id          String    @id @default(uuid())
  name        String
  amount      Int
  cycleType   CycleType @map("cycle_type")
  cycleDay    Int       @map("cycle_day")
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  walletId    String    @map("wallet_id")
  wallet      Wallet    @relation(fields: [walletId], references: [id])
  categoryId  String    @map("category_id")
  category    Category  @relation(fields: [categoryId], references: [id])
}

model Budget {
  id         String   @id @default(uuid())
  amount     Int
  month      String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  walletId   String   @map("wallet_id")
  wallet     Wallet   @relation(fields: [walletId], references: [id])
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])
}

model Reminder {
  id              String         @id @default(uuid())
  type            ReminderType
  title           String
  description     String?
  dueDate         DateTime?      @map("due_date")
  isRead          Boolean        @default(false) @map("is_read")
  createdAt       DateTime       @default(now()) @map("created_at")
  userId          String         @map("user_id")
  user            User           @relation(fields: [userId], references: [id])
  recurringBillId String?        @map("recurring_bill_id")
  recurringBill   RecurringBill? @relation(fields: [recurringBillId], references: [id])
}